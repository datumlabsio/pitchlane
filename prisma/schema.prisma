generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}


enum SourceCompleteness {
  PARTIAL
  FULL
}

enum LeadStatus {
  NEW
  QUALIFIED
  REJECTED
  APPLIED
  CLIENT_REPLIED
  INTRO_CALL
  FOLLOW_UP
  ONGOING_DISCUSSION
  HIRES_OTHER
  QUALIFIED_LOST
  JOB_CLOSED
  WON
  LOST
  CLOSED
}

enum LeadSource {
  UPWORK
  EMAIL_FORWARD
  INVITE
  MANUAL
}

enum ProposalTone {
  CONSULTATIVE
  DIRECT
  EXPERT
  FRIENDLY
}

enum IntegrationProvider {
  GOOGLE_GMAIL
  UPWORK
}

model Account {
  id                  String          @id @default(cuid())
  name                String
  personName          String
  upworkProfileUrl    String?
  gmailLabel          String          @unique
  forwardingInbox     String
  notificationEmail   String?
  isActive            Boolean         @default(true)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  profileConfigs      ProfileConfig[]
  leads               Lead[]
  applications        Application[]
}

model ProfileConfig {
  id                   String               @id @default(cuid())
  accountId            String
  name                 String
  roleFocus            String
  jdSummary            String               @db.Text
  targetRoles          String[]
  targetKeywords       String[]
  requiredSkills       String[]
  niceToHaveSkills     String[]
  rejectRules          String[]
  budgetPreference     String?
  scoreThreshold       Int                  @default(75)
  proposalTone         ProposalTone         @default(CONSULTATIVE)
  proposalRules        String[]
  reusableSnippets     String[]
  scoringWeights       Json
  version              Int                  @default(1)
  isActive             Boolean              @default(true)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  account              Account              @relation(fields: [accountId], references: [id], onDelete: Cascade)
  evaluations          LeadEvaluation[]
  proposals            ProposalVersion[]

  @@index([accountId, isActive])
}

model Lead {
  id                   String               @id @default(cuid())
  accountId            String
  title                String
  source               LeadSource           @default(UPWORK)
  externalMessageId    String?              @unique
  externalThreadId     String?
  sourceUrl            String?
  sender               String?
  emailSubject         String?
  emailSnippet         String?              @db.Text
  rawEmailBody         String?              @db.Text
  extractedBudget      String?
  extractedSkills      String[]
  sourceCompleteness   SourceCompleteness   @default(PARTIAL)
  enrichment           Json?
  enrichedAt           DateTime?
  confidence           Int                  @default(50)
  dedupeKey            String               @unique
  status               LeadStatus           @default(NEW)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  account              Account              @relation(fields: [accountId], references: [id], onDelete: Cascade)
  evaluations          LeadEvaluation[]
  proposals            ProposalVersion[]
  applications         Application[]
  events               LeadEvent[]

  @@index([accountId, status])
  @@index([externalThreadId])
}

model LeadEvaluation {
  id                   String        @id @default(cuid())
  leadId               String
  profileConfigId      String
  score                Int
  hardFilterPassed     Boolean
  rejectionReasons     String[]
  matchedKeywords      String[]
  summary              String[]
  confidence           Int
  createdAt            DateTime      @default(now())
  lead                 Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  profileConfig        ProfileConfig @relation(fields: [profileConfigId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt])
}

model ProposalVersion {
  id                   String        @id @default(cuid())
  leadId               String
  profileConfigId      String
  content              String        @db.Text
  isPrimary            Boolean       @default(true)
  isAiGenerated        Boolean       @default(true)
  createdAt            DateTime      @default(now())
  lead                 Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)
  profileConfig        ProfileConfig @relation(fields: [profileConfigId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt])
}

model Application {
  id                   String       @id @default(cuid())
  accountId            String
  leadId               String
  connectsSpent        Int?
  appliedAt            DateTime?
  lastFollowUpAt       DateTime?
  notes                String?      @db.Text
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  account              Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)
  lead                 Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)
}

model LeadEvent {
  id                   String       @id @default(cuid())
  leadId               String
  type                 String
  payload              Json?
  createdAt            DateTime     @default(now())
  lead                 Lead         @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt])
}

model IntegrationConnection {
  id                   String              @id @default(cuid())
  provider             IntegrationProvider @unique
  email                String?
  accessToken          String?             @db.Text
  refreshToken         String?             @db.Text
  expiryDate           DateTime?
  scopes               String[]
  metadata             Json?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  syncRuns             SyncRun[]
}

model SyncRun {
  id                   String              @id @default(cuid())
  provider             IntegrationProvider
  startedAt            DateTime            @default(now())
  finishedAt           DateTime?
  status               String
  messagesScanned      Int                 @default(0)
  leadsCreated         Int                 @default(0)
  duplicatesSkipped    Int                 @default(0)
  errorsCount          Int                 @default(0)
  errorSummary         String?             @db.Text
  metadata             Json?
  integrationId        String?
  integration          IntegrationConnection? @relation(fields: [integrationId], references: [id], onDelete: SetNull)

  @@index([provider, startedAt])
}
